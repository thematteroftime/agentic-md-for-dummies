"""MyAggregator — paper-specific cross-run report builder.

Implements the aggregator contract from docs/ARCHITECTURE.md §3.6:
  static aggregate(run_dirs, output, plots, title, **params) -> None

Called by Phase 4 of the pipeline (after all production runs complete) to
synthesize a master report. Renders cross-run figures by calling the plotter's
fig_*  methods, writes a markdown report at `output`.

To activate:
  1. Save this file as `tools/aggregators/<topic>.py`
  2. **RENAME** the class `MyAggregator` below to `<PaperSlug>Aggregator`.
  3. Register in `tools/registry.py:_REGISTRY`:
       "<PaperSlug>Aggregator": "tools.aggregators.<topic>:<PaperSlug>Aggregator"
  4. Mirror in `tools/aggregators/__init__.py`.
  5. Reference in your config:
       "aggregation": {"enabled": true, "class": "<PaperSlug>Aggregator",
                       "output": "docs/<paper>_campaign_report.md",
                       "plots": ["overview", ...]}

Contract:
  - REQUIRED: `aggregate(run_dirs, output, plots, title, **params)`
  - REQUIRED side effect: write the master `<output>` markdown
  - REQUIRED side effect: render each named cross-run figure into
    `docs/images/<paper>_<plot>.png` (linked from the markdown)
  - OPTIONAL: rich tables, comparison stats, paper-target overlays
"""
from __future__ import annotations
from pathlib import Path
from typing import Iterable

# Import the analyzer + plotter from the same paper package.
# The analyzer's load_run is the canonical record loader; the plotter's
# fig_* methods are the canonical cross-run figure renderers.
from tools.analyzers.<topic> import MyAnalyzer  # RENAME: <PaperSlug>Analyzer
from tools.plotters.<topic>  import MyPlotter   # RENAME: <PaperSlug>Plotter


class MyAggregator:                          # RENAME this class — see header comment
    """Paper <CITATION> cross-run aggregator."""

    @staticmethod
    def aggregate(run_dirs: Iterable, output: str, plots, title: str = "", **params):
        """Render cross-run figures and write the master markdown report.

        run_dirs: iterable of Path / str pointing at completed run dirs
        output:   path to the master markdown (e.g. docs/<paper>_campaign_report.md)
        plots:    list of fig_* short names to render (e.g. ["overview", "msd"])
        title:    report title
        params:   forwarded from aggregation.params (paper-specific knobs)
        """
        run_dirs = [Path(p) for p in run_dirs]
        records = [MyAnalyzer.load_run(rd) for rd in run_dirs]

        out_md = Path(output)
        out_md.parent.mkdir(parents=True, exist_ok=True)
        img_dir = Path("docs/images")
        img_dir.mkdir(parents=True, exist_ok=True)

        # 1. Render cross-run figures by name
        fig_paths = []
        for short in plots or []:
            method = getattr(MyPlotter, f"fig_{short}", None)
            if method is None:
                print(f"[aggregator] plot '{short}' has no fig_{short} method — skipping")
                continue
            out_png = img_dir / f"<paper>_{short}.png"
            method(records, out_png, **params)
            fig_paths.append(out_png)

        # 2. Write master markdown
        lines = [f"# {title or 'Campaign report'}", ""]
        lines.append(f"Runs: {len(records)}")
        lines.append("")
        lines.append("| Tag | T0 | rho | verdict |")
        lines.append("| --- | --- | --- | --- |")
        for rec in records:
            man = rec["manifest"]
            lines.append(
                f"| {man.get('tag', '?')} | {man.get('T0', '?')} | "
                f"{man.get('rho', '?')} | {man.get('verdict', 'N/A')} |"
            )
        lines.append("")
        for png in fig_paths:
            lines.append(f"![{png.stem}]({png.relative_to(out_md.parent)})")
            lines.append("")
        out_md.write_text("\n".join(lines), encoding="utf-8")
        print(f"[aggregator] wrote {out_md}")
